    {
      "name": "Invoices",
      "item": [
        {
          "name": "POST Create Voice Invoice (Whisper)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.invoice?.id) pm.environment.set('invoiceId', json.invoice.id);",
                  "if (json.invoice?.pdfUrl) pm.environment.set('pdfUrl', json.invoice.pdfUrl);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "audio",
                  "type": "file",
                  "src": "{{audioFilePath}}"
                },
                {
                  "key": "language",
                  "value": "mixed",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/invoice/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "invoice",
                "create"
              ]
            }
          },
          "response": []
        },
